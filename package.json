{
  "name": "vite-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:bubble-flow": "tsx scripts/bubble-flow-e2e.ts",
    "test:e2e:upload-thumbnail-bubble": "tsx scripts/upload-thumbnail-bubble-e2e.ts",
    "test:e2e:batch-price": "tsx scripts/digifabster-batch-price-e2e.ts",
    "test:e2e:place-order": "tsx scripts/digifabster-place-order-e2e.ts",
    "test:sheet-nesting:dxf": "tsx scripts/sheet-nesting-dxf-proof.ts",
    "test:viewer:ui": "pnpm test:e2e -- e2e/viewer-and-conversion.spec.ts",
    "test:viewer:contracts": "tsx scripts/viewer-resilience-smoke.ts",
    "test:viewer:guardrail": "pnpm test:viewer:ui && pnpm test:viewer:contracts",
    "build:cloudflare": "vite build --config vite.config.cloudflare.ts",
    "pages:dev": "pnpm build:cloudflare && wrangler pages dev",
    "pages:deploy": "pnpm build:cloudflare && wrangler pages deploy",
    "price-scheduler:deploy": "wrangler deploy --config workers/price-scheduler/wrangler.toml",
    "price-scheduler:tail": "wrangler tail --config workers/price-scheduler/wrangler.toml"
  },
  "dependencies": {
    "@makeorbreakshop/any-nest": "^1.1.0",
    "@vercel/blob": "^2.3.3",
    "@vercel/node": "^5.0.2",
    "any-nest": "^1.0.3",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "dxf-parser": "^1.1.2",
    "dxf-writer": "^1.18.4",
    "express": "^4.21.2",
    "fflate": "^0.8.2",
    "json-nest": "^1.0.4",
    "lodash": "^4.17.21",
    "multer": "1.4.5-lts.1",
    "next": "15.1.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.2",
    "svgnest-mjs": "^1.0.0",
    "vite-plugin-api-routes": "1.2.0-beta"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@playwright/test": "^1.59.1",
    "@types/express": "^5.0.0",
    "@types/forge-viewer": "^7.89.1",
    "@types/multer": "^1.4.12",
    "@types/next": "^9.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@cloudflare/workers-types": "^4.20240909.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "tsx": "^4.20.5",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.1",
    "vite": "^5.4.1",
    "vite-plugin-vercel": "^9.0.4",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^3.78.0"
  }
}
